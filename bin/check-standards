#!/usr/bin/env python3
"""Check ADAMA standards for internal consistency.

Verifies that standards don't reference retired enum values, field names,
or section names that have been superseded. Run after any standards change.

Usage:
  ./bin/check-standards            # check, exit 0 = clean, exit 1 = drift found
  ./bin/check-standards --verbose  # also print all checks passed
"""

import re, sys, os

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
ADAMA_ROOT = os.path.dirname(SCRIPT_DIR)
STANDARDS_DIR = os.path.join(ADAMA_ROOT, "standards")

# Each check: (description, pattern, files_to_search)
# Patterns are regex, matched case-sensitively unless flagged.
CHECKS = [
    # ── Retired lifecycle enums (pre-phase-model) ──
    (
        "Retired 'state' field (replaced by phase/status in outpost-state.md)",
        r"^state:\s*(?!null)",
        ["outpost-state.md", "dashboard-derivation.md", "agents.md"],
    ),
    (
        "Retired enum 'operational' (replaced by phase: outpost)",
        r"operational",
        ["dashboard-derivation.md", "outpost-state.md", "agents.md"],
    ),
    (
        "Retired enum 'commissioning' (replaced by phase: survey)",
        r"commissioning",
        ["dashboard-derivation.md", "outpost-state.md", "agents.md"],
    ),
    (
        "Retired enum 'transiting' (replaced by phase model)",
        r"transiting",
        ["dashboard-derivation.md", "outpost-state.md", "agents.md"],
    ),
    # ── Retired section names ──
    (
        "Retired section '## Next Actions' (replaced by ## Full Backlog)",
        r"## Next Actions",
        ["agents.md", "outpost-state.md", "init-outpost.md"],
    ),
    # ── OKF status collision ──
    (
        "OKF bare 'status:' for publication (renamed to publication_status)",
        r"^status:\s*(active|draft|archived)",
        ["okf.md"],
    ),
    # ── Legacy name references ──
    (
        "Legacy name 'sisko' (renamed to ADAMA)",
        r"[Ss]isko",
        ["agents.md", "outpost-state.md", "dashboard-derivation.md",
         "init-outpost.md", "okf.md", "git.md"],
    ),
]

# Files that are allowed to mention a pattern (e.g., in changelog/decisions).
# Map: pattern_string -> set of filenames to skip.
SKIP_FILES = {
    "sisko": {"hot.md"},  # hot.md documents the rename
}


def check_standards(verbose=False):
    """Return list of (description, file, line_number, line) drift findings."""
    drift = []
    checks_passed = 0

    for description, pattern, files in CHECKS:
        regex = re.compile(pattern, re.MULTILINE)
        found_drift = False

        for fname in files:
            fpath = os.path.join(STANDARDS_DIR, fname)
            if not os.path.exists(fpath):
                continue

            # Check skip list
            pattern_key = None
            for key in SKIP_FILES:
                if key in pattern:
                    pattern_key = key
                    break
            if pattern_key and fname in SKIP_FILES[pattern_key]:
                continue

            with open(fpath, "r", encoding="utf-8") as f:
                content = f.read()

            for i, line in enumerate(content.splitlines(), 1):
                if regex.search(line):
                    drift.append((description, fname, i, line.strip()))
                    found_drift = True

        if not found_drift:
            checks_passed += 1
            if verbose:
                print(f"  PASS: {description}")

    if verbose:
        print(f"\n{checks_passed}/{len(CHECKS)} checks passed")

    return drift


if __name__ == "__main__":
    verbose = "--verbose" in sys.argv
    drift = check_standards(verbose=verbose)

    if drift:
        print(f"\nDRIFT FOUND ({len(drift)} issue{'s' if len(drift) != 1 else ''}):\n")
        for desc, fname, lineno, line in drift:
            print(f"  {fname}:{lineno} — {desc}")
            print(f"    > {line}")
            print()
        sys.exit(1)
    else:
        if not verbose:
            print("Standards consistent — no drift found.")
        sys.exit(0)
